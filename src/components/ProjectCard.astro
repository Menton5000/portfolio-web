---
interface Props {
  name: string;
  description: string;
  url: string;
  language?: string;
  stars?: number;
  topics?: string[];
}

const { name, description, url, language, stars = 0, topics = [] } = Astro.props;

const langColors: Record<string, string> = {
  Python: '#3572A5',
  JavaScript: '#f1e05a',
  TypeScript: '#2b7489',
  C: '#555555',
  'C++': '#f34b7d',
  Rust: '#dea584',
  Go: '#00ADD8',
  Java: '#b07219',
  HTML: '#e34c26',
  CSS: '#563d7c',
  Shell: '#89e051',
  Astro: '#ff5a03',
};

const langColor = language ? (langColors[language] ?? '#94a3b8') : '#94a3b8';
---

<a href={url} target="_blank" rel="noopener noreferrer" class="project-card">
  <div class="card-header">
    <svg class="repo-icon" viewBox="0 0 16 16" fill="currentColor">
      <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
    </svg>
    <span class="repo-name">{name}</span>
    <svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M15 3h6v6M10 14 21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
    </svg>
  </div>

  <p class="description">{description}</p>

  {topics.length > 0 && (
    <div class="topics">
      {topics.map(t => <span class="topic">{t}</span>)}
    </div>
  )}

  <div class="card-footer">
    {language && (
      <span class="lang">
        <span class="lang-dot" style={`background:${langColor}`}></span>
        {language}
      </span>
    )}
    {stars > 0 && (
      <span class="stars">
        <svg viewBox="0 0 16 16" fill="currentColor" width="13" height="13">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
        </svg>
        {stars}
      </span>
    )}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: background 0.25s, border-color 0.25s, transform 0.25s, box-shadow 0.25s;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(220,38,38,0.08) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: inherit;
  }

  .project-card:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(220,38,38,0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(220,38,38,0.15);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .repo-icon {
    width: 16px;
    height: 16px;
    color: #94a3b8;
    flex-shrink: 0;
  }

  .repo-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #f87171;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .external-icon {
    width: 14px;
    height: 14px;
    color: #475569;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .project-card:hover .external-icon {
    color: #f87171;
  }

  .description {
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.6;
    flex: 1;
  }

  .topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .topic {
    font-size: 0.7rem;
    padding: 0.2rem 0.55rem;
    background: rgba(220,38,38,0.15);
    color: #f87171;
    border-radius: 999px;
    border: 1px solid rgba(220,38,38,0.25);
    font-weight: 500;
  }

  .card-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
  }

  .lang {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: #94a3b8;
  }

  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .stars {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    color: #94a3b8;
  }
</style>
